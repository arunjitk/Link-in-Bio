# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Your personal Telegram chat ID (where messages will be forwarded).
# To get it: send /start to your bot, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# and copy the "chat":{"id": ...} value.
TELEGRAM_CHAT_ID=123456789

# Internal port (leave at 3001 unless you change docker-compose too)
PORT=3001
